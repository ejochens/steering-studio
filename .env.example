# Copy this file to .env and adjust as needed.
# The setup script (scripts/setup.ps1) creates .env automatically if missing.

DATABASE_URL="file:./dev.db"

# Optional: encryption key for provider secrets stored in the database.
# If not set, a default development key is used (not suitable for production).
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY="your-64-char-hex-key-here"

# Optional: if you are behind a corporate proxy with TLS inspection,
# point to your corporate CA certificate instead of disabling TLS validation.
# NODE_EXTRA_CA_CERTS="C:\path\to\corporate-ca.pem"
